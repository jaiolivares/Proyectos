generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  Id               Int       @id @default(autoincrement())
  NombreUsuario    String    @unique(map: "NombreUsuario_UNIQUE") @db.VarChar(100)
  Password         String   @db.VarChar(100)
  Nombre           String   @db.VarChar(50)
  SegundoNombre    String?   @db.VarChar(50)
  ApellidoPaterno  String   @db.VarChar(50)
  ApellidoMaterno  String?   @db.VarChar(50)
  Email            String   @db.VarChar(100)
  FechaCreacion    DateTime @db.DateTime(0)
  FechaUltimoLogin DateTime? @db.DateTime(0)
  EstaBloqueado    Int      @db.TinyInt
  EstaActivo       Int      @db.TinyInt
}

model Vehiculo {
  Id                     Int       @id @default(autoincrement())
  IdMarcaModeloVehiculo  Int
  Ano                    Int
  NumeroMotor            String    @db.VarChar(20)
  NumeroChasis           String    @db.VarChar(30)
  Color                  String    @db.VarChar(20)
  FechaCompra            DateTime  @db.DateTime(0)
  MontoCompra            Int
  Vendido                Int       @db.TinyInt
  FechaVenta             DateTime? @db.DateTime(0)
  MontoVenta             Int?

  @@map("Vehiculo")
}

model TipoVehiculo {
  Id          Int    @id @default(autoincrement())
  Tipo        String @db.VarChar(20)
  Descripcion String @db.VarChar(60)

  @@map("TipoVehiculo")
}

model MarcaVehiculo {
  Id          Int    @id @default(autoincrement())
  Marca       String @db.VarChar(20)
  Descripcion String @db.VarChar(60)

  @@map("MarcaVehiculo")
}

model ModeloVehiculo {
  Id             Int    @id @default(autoincrement())
  IdTipoVehiculo Int
  Modelo         String @db.VarChar(20)
  Descripcion    String @db.VarChar(60)

  @@map("ModeloVehiculo")
}

model MarcaModeloVehiculo {
  Id       Int @id @default(autoincrement())
  IdMarca  Int
  IdModelo Int

  @@map("MarcaModeloVehiculo")
}

model Taller {
  Id       Int    @id @default(autoincrement())
  Nombre   String @db.VarChar(100)
  IdComuna Int
  Direccion String @db.VarChar(200)

  @@map("Taller")
}
